PORT=3000

# Logto Configuration
LOGTO_ENDPOINT=https://auth.learnsocialstudies.com
LOGTO_ISSUER=https://your-logto-issuer
LOGTO_JWKS_URL=https://your-logto-jwks-url

# Logto Management API Configuration
LOGTO_MANAGEMENT_API_TOKEN_ENDPOINT=https://your-logto-endpoint/oidc/token
LOGTO_MANAGEMENT_API_APPLICATION_ID=your-application-id
LOGTO_MANAGEMENT_API_APPLICATION_SECRET=your-application-secret
LOGTO_MANAGEMENT_API_RESOURCE=https://default.logto.app/api

# API Resource
API_RESOURCE_INDICATOR=https://api.learnsocialstudies.com

# ─── Phase 2A ─────────────────────────────────────────────────────────────
LOGTO_WEBHOOK_SECRET=        # Logto Console > Webhooks > Signing Key
RETAIL_ORG_ID=               # Logto Console > Organizations > Retail org ID
WP_API_USER=                 # WordPress admin username
WP_API_PASSWORD=             # WordPress > Users > Application Passwords
FLUENTCRM_API_USER=          # FluentCRM manager username (Settings > REST API)
FLUENTCRM_APP_PASSWORD=      # WordPress > Users > Application Password for FluentCRM user
MOODLE_API_TOKEN=            # Moodle > Site Admin > Web Services > Tokens

# ─── Phase 2B ─────────────────────────────────────────────────────────────
FLUENTCRM_WEBHOOK_SECRET=    # Custom header secret for FluentCRM Outgoing Webhooks
ROLES_WEBHOOK_SECRET=        # Custom header secret for role-sync webhook
MOODLE_PREMIUM_COURSE_ID=    # Moodle course ID to enroll Retail users on subscription activation

# ─── Phase 2C ─────────────────────────────────────────────────────────────
BUDDYBOSS_SCHOOL_GROUP_TYPE=   # BuddyBoss group type slug for schools
MOODLE_DEFAULT_CATEGORY_ID=    # Root category ID for school sub-categories
# MOODLE_COURSE_{SLUG}_ID=     # Per-course IDs (e.g. MOODLE_COURSE_IB_MATH_ID)